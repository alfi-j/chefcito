# MongoDB Configuration
# Option A – local: URI without database name + explicit MONGODB_DB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=chefcito
# Option B – Atlas: database name is embedded in the URI, MONGODB_DB is optional
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/chefcito?retryWrites=true&w=majority

# PayPhone Cajita de Pagos Configuration
# Server-side only — never prefix with NEXT_PUBLIC_
PAYPHONE_TOKEN=your_api_token_here
PAYPHONE_STORE_ID=your_store_id_here
# Google OAuth (Google Identity Services)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# Base URL — fuente única para todas las rutas de la app (invites, PayPhone redirectUrl, página de error)
# Rutas derivadas automáticamente:
#   PayPhone éxito  → $NEXT_PUBLIC_BASE_URL/thank-you
#   PayPhone error  → $NEXT_PUBLIC_BASE_URL/error
NEXT_PUBLIC_BASE_URL=http://localhost:3000
