# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=chefcito

# For MongoDB Atlas, use a connection string like:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/chefcito?retryWrites=true&w=majority

# PayPhone Cajita de Pagos Configuration
# Server-side (para confirmación de pagos)
PAYPHONE_TOKEN=your_private_api_token_here
PAYPHONE_STORE_ID=your_store_id_here

# Client-side (para el componente de pago en el frontend)
NEXT_PUBLIC_PAYPHONE_TOKEN=your_public_api_token_here
NEXT_PUBLIC_PAYPHONE_STORE_ID=your_public_store_id_here

# Payphone Return URL (para redirección después del pago)
# En producción, cambia localhost por tu dominio
NEXT_PUBLIC_PAYPHONE_RETURN_URL=http://localhost:3000/api/payphone/success
